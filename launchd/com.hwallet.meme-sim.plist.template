<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.hwallet.meme-sim</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__REPO_ROOT__/scripts/run_scheduled_tick.sh</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__REPO_ROOT__</string>
  <key>StartInterval</key>
  <integer>__SCAN_INTERVAL__</integer>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>__REPO_ROOT__/logs/launchd-sim.stdout.log</string>
  <key>StandardErrorPath</key>
  <string>__REPO_ROOT__/logs/launchd-sim.stderr.log</string>
</dict>
</plist>
